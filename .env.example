# Supabase project values from: Supabase Dashboard -> Project Settings -> API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY

# Optional aliases supported by the code as well:
# VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY

# Vercel/Nitro target. vite.config.ts already pins this, but keeping it in Vercel is OK.
NITRO_PRESET=vercel
